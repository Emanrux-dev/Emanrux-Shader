    value.OVERDRAW_MAX_DISTANCE.176 = 11 Chunks
    value.OVERDRAW_MAX_DISTANCE.192 = 12 Chunks
    value.OVERDRAW_MAX_DISTANCE.208 = 13 Chunks
    value.OVERDRAW_MAX_DISTANCE.224 = 14 Chunks
    value.OVERDRAW_MAX_DISTANCE.240 = 15 Chunks
    value.OVERDRAW_MAX_DISTANCE.256 = 16 Chunks
option.DH_CHUNK_FADING = Desvanecimento de Chunks
    value.DH_CHUNK_FADING.0 = Desligado
    value.DH_CHUNK_FADING.1 = Terreno
    value.DH_CHUNK_FADING.2 = Terreno + Sombras

option.DH_AMBIENT_OCCLUSION = Oclusão Ambiente em Chunks LOD
option.DH_SUBSURFACE_SCATTERING = Dispersão Subsuperficial em Chunks LOD
option.DH_SCREENSPACE_REFLECTIONS = Reflexos no Espaço de Ecrã em Chunks LOD

option.DISTANT_HORIZONS_SHADOWMAP = §c(NÃO USE SE NÃO SABE O QUE É ISTO)§r Suporte ao mapa de sombras DH
option.DISTANT_HORIZONS_SHADOWMAP.comment =  §cESTA DEFINIÇÃO VAI DESTRUIR O DESEMPENHO ISTO TORNARÁ AS SOMBRAS COM ASPECTO DE BLOCOS, CINTILANTES E DE BAIXO DETALHE§r. defina a distância de sombras para 32 chunks (ou mais). defina a resolução de sombras para 4096 (ou mais)
option.TOGGLE_VL_FOG = Activar/Desactivar Nevoeiro Volumétrico
option.TOGGLE_VL_FOG.comment = um grande botão para simplesmente desligar todo o nevoeiro.

screen.VOXY_SETTINGS = Definições Voxy
    option.VOXY_AMBIENT_OCCLUSION = Oclusão Ambiente em Chunks LOD
    option.VOXY_SSS = Dispersão Subsuperficial em Chunks LOD
    option.VOXY_REFLECTIONS = Reflexos no Espaço de Ecrã em Chunks LOD

screen.PHOTONICS_SETTINGS = Definições Photonics
    option.PHOTONICS_ACTIVE = Activar Photonics
    option.PHOTONICS_INDIRECT_BRIGHTNESS = Brilho GI
    option.PHOTONICS_GI_ONLY = Apenas GI
    option.PHOTONICS_FLOODFILL_FOG_LIGHT_PROPAGATION = Propagação de Luz no Nevoeiro (Floodfill!)


option.TRANSLUCENT_COLORED_SHADOWS.comment = §bO que é isto?§r Este efeito permite que coisas translúcidas como vidro colorido tinjam a luz solar ao passar através delas. §aCUSTO DE DESEMPENHO:§r médio
option.MINIMUM_WATER_ABSORBANCE.comment = §bO que é isto?§r Isto controla o quão "clara" é a água em áreas pouco profundas. AUTO permite que a água seja clara no exterior, mas ajusta para um valor mínimo de 7 quando está em interiores, para a tornar claramente visível. §dESTA DEFINIÇÃO NÃO AFECTA OS VISUAIS DEBAIXO DE ÁGUA.        

option.SATURATION.comment = §bO que é isto?§r Isto controla o quão "colorida" é a imagem. valores negativos retiram cores - valores positivos tornam-nas mais intensas.
option.CROSSTALK.comment = §bO que é isto?§r Este é um modificador de saturação - compensa a saturação das partes BRILHANTES da imagem.
option.WHITE_BALANCE.comment = §bO que é isto?§r Isto controla o aspecto quente ou frio da imagem - equilibra os azuis e vermelhos.
option.TAA_MODE.comment = §bStandard:§r tem a melhor capacidade de anti-aliasing - usa mais desvios de jitter, mas precisa de mais historial de frames (defina o factor de mistura mais baixo), vai cintilar mais e ter mais artefactos de movimento. §bResponsivo:§r tem a pior capacidade de anti-aliasing - usa menos desvios de jitter, precisa de menos historial de frames (defina o factor de mistura mais alto), por isso pode ter menos artefactos de movimento. §bUpscaling Temporal:§r Renderiza o shader a uma resolução de janela mais baixa, e depois dimensiona-a de volta para caber no ecrã para melhor desempenho - tem MUITOS artefactos.
option.MOTION_BLUR.comment = §bO que é isto?§r Este efeito faz com que todo o ecrã desfoque na direcção em que move a câmara, ou para onde se move no mundo. §aCUSTO DE DESEMPENHO:§r muito baixo
option.CHROMATIC_ABERRATION.comment = §bO que é isto?§r Este efeito faz com que as bordas do ecrã tenham um desvio de cor de vermelho e azul. §aCUSTO DE DESEMPENHO:§r muito muito baixo
option.VIGNETTE.comment = §bO que é isto?§r Este efeito faz com que as bordas do ecrã fiquem cada vez mais escuras quanto mais perto das bordas estiver. §aCUSTO DE DESEMPENHO:§r muito muito baixo
option.TONEMAP.comment = §bO que é isto?§r Isto ajusta o HDR interno ou qualquer gama de cor que o shader está a fazer, para parecer bem no seu monitor SDR. vai controlar o processamento geral de cor - o contraste, saturação, ponto branco, ponto negro, desvio de matiz, caminho para branco, etc. - cada um tem um aspecto diferente
option.DOF_QUALITY.comment= §bO que é isto?§r Este é o desfoque de "desenfoque" no fundo e primeiro plano quando uma câmara foca a sua lente em algo, por vezes referido como "bokeh". §aCUSTO DE DESEMPENHO:§r baixo a alto
option.MANUAL_FOCUS.comment= §bO que é isto?§r controlar como a lente da câmara foca. "Foco Automático" focará no que olha. "Controlo Deslizante de Brilho" permite focar manualmente usando a definição de brilho nas opções de vídeo. "Foco Manual" apenas foca num ponto fixo a alguma distância da câmara em metros.
option.DOF_ANAMORPHIC_RATIO.comment= §bO que é isto?§r Esta é uma recriação da distorção da lente Anamórfica, onde irá esticar o desfocado/bokeh. 
