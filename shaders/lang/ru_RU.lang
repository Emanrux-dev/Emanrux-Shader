    value.EMISSIVE_TRIMS.1 = Вкл (не перезаписывать свечение labPBR)
    value.EMISSIVE_TRIMS.2 = Вкл (перезаписывать свечение labPBR)
option.EMISSIVE_TRIMS_STRENGTH = Яркость светящихся отделок

option.PLANET_CURVATURE = Кривизна планеты §c(VOXY НЕ ПОДДЕРЖИВАЕТСЯ!)
option.CURVATURE_AMOUNT = Количество кривизны

option.VANILLA_CHUNK_FADING = Появление чанков §c(Iris 1.10.3+)
